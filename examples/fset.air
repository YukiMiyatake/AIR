(mod fset_ex
  (struct Point
    (
      (x i32)
      (y i32)
    )
  )
  (fn main () i32
    (let
      (
        (p (named Point)
          (struct_lit Point
            (x (lit i32 3))
            (y (lit i32 4))
          )
        )
      )
      (seq
        (call fset (var p) x (lit i32 10))
        (field (var p) x)
      )
    )
  )
)
